MONGODB_URI=
MONGODB_USER=<db_username>
MONGODB_PASS=<db_password>
MONGODB_HOST=cluster0.m8hcwvr.mongodb.net
MONGODB_DB=<db_name>
MONGODB_OPTIONS=retryWrites=true&w=majority&appName=Cluster0
PORT=8080
NODE_ENV=development

CORS_ORIGIN=http://localhost:3000
CORS_DISABLED=false
# For public API (no cookies), use: CORS_ORIGIN=*
# For multiple origins, use comma-separated values.

JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_EXPIRES=15m
JWT_REFRESH_EXPIRES=14d

ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=StrongPass